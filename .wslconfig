#Win + R, type %USERPROFILE%, and hit Enter.

[wsl2]
# Perfect choice. Keeps Windows breathing safely on 8GB total RAM.
memory=2GB
# Upgraded to 6: Your Ryzen 7 can easily spare 6 threads for compilation handles.
processors=6
# Crucial fallback for your 2GB RAM limit.
swap=4GB
guiApplications=false

[experimental]
autoMemoryReclaim=gradual
sparseVhd=true

#old 
#[experimental]
#autoMemoryReclaim=gradual
#sparseVhd=true
#networkingMode=mirrored
#dnsTunneling=true
#firewall=true
#autoProxy=true
#hostAddressLoopback=true
